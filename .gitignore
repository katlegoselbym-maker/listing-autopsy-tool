# ============================================================
# 72-Hour Listing Autopsy — .gitignore
# ============================================================

# Environment variables — never commit your API key
.env
.env.local
.env.development
.env.production
.env*.local

# Vercel local configuration
.vercel

# Node modules — if you ever add dependencies locally
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows system files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Editor and IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Log files
logs/
*.log

# Build output (if you ever add a build step)
dist/
build/
.cache/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
